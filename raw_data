            if m_tot < 5:
              a.append('massa bassa(stelle di neutroni); ')
            if luminosity_distance < 500:
              a.append('distanza luminosa(vicinanza); ')
            if chi_eff> 0.5:
              a.append('velocità di rotazione; ')
            motivazioni="".join(a)
            
          # Stampiamo la riga
