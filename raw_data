        # --- 2. Gestione Rilevatori (Dato che mancano nelle chiavi) ---
        # Se non ci sono nelle chiavi, usiamo la logica temporale GPS
        if gps < 1185920000: 
            ril = "H1, L1"
        else:
            ril = "H1, L1, V1"

        #if not ril: ril = "N/D"

        # Logica di interpretazione per l'oggetto
        if m1 < 3 and m2 < 3:
            obj = 'Neutron Stars (BNS)'
        elif m1 > 25 and m2 > 25:
            obj = 'Black Holes (BBH)'
        elif (m1 < 3 and m2 > 25) or (m1 > 25 and m2 < 3):
            obj = 'Mixed (NSBH)'
        else:
            obj = 'Unknown / Intermediate'

        snr_r = info.get('network_snr_peak') or 0
        snr= float(snr_r)
        far_r = info.get('far') or 0
        far= float(far_r)
        m_tot = m1 + m2
        luminosity_distance_r=info.get('luminosity_distance') or 0
        luminosity_distance=float(luminosity_distance_r)
        chi_eff_r=info.get('chi_eff') or 0
        chi_eff= float(chi_eff_r)
        if m_tot !=0 and luminosity_distance !=0 and chi_eff != 0:
          # Esempio di filtro: Evento "Eccezionale"
          if snr > 25 or far < 1e-15 or m_tot > 150 or m_tot<5 or luminosity_distance<500 or chi_eff> 0.5 :
